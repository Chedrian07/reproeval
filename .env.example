# codebench API configuration
# Copy this to .env and fill in your values

# Provider: openai_responses or openai_chat_completions
CODEBENCH_PROVIDER=openai_responses

# Model name
CODEBENCH_MODEL=gpt-5.4-mini

# API key (or the value itself)
CODEBENCH_API_KEY=api

# API base URL (for local/proxy servers)
CODEBENCH_BASE_URL=http://localhost:8317

# Sandbox backend: local or docker
CODEBENCH_SANDBOX=local

# Max instances per dataset (empty = all)
CODEBENCH_MAX_INSTANCES=

# Sampling parameters (empty = use defaults)
CODEBENCH_TEMPERATURE=0.0
CODEBENCH_TOP_P=
CODEBENCH_MIN_P=
CODEBENCH_TOP_K=
CODEBENCH_FREQUENCY_PENALTY=
CODEBENCH_PRESENCE_PENALTY=

# Reasoning effort for OpenAI Responses API: low / medium / high (empty = off)
CODEBENCH_REASONING_EFFORT=

# Parallel requests per dataset (1 = sequential, 8 = 8 concurrent API calls)
CODEBENCH_CONCURRENCY=1

# Debug mode: live scoreboard showing real-time pass/fail per instance
CODEBENCH_DEBUG=off
